# Paste your Kimi / Moonshot API key here.
MOONSHOT_API_KEY=
MOONSHOT_API_BASE=https://api.moonshot.ai/v1

# ── OpenAI / Codex OAuth sign-in (alternative to pasting OPENAI_API_KEY) ───────
# Sign in with your ChatGPT/OpenAI account from the dashboard (Settings →
# Authentication), the CLI (`PYTHONPATH=src python -m auth login`), or the
# gateway. It mints an OpenAI API key from your account and stores it at
# AGENT_AUTH_FILE. Defaults target the public Codex client; override only if you
# registered your own OAuth app.
# AGENT_AUTH_FILE=                    # default: ~/.agent-ai/codex_auth.json
# CODEX_CLIENT_ID=                    # default: public Codex CLI client
# CODEX_OAUTH_ISSUER=https://auth.openai.com
# CODEX_REDIRECT_URI=http://localhost:1455/auth/callback
# CODEX_API_KEY_ENV=OPENAI_API_KEY    # env var the minted key is written to

AGENT_MODEL=moonshot/kimi-k2.6
FAST_AGENT_MODEL=moonshot/kimi-k2.6
STRONG_AGENT_MODEL=moonshot/kimi-k2.6

AGENT_ACTION_MAX_REACT_ITERATIONS=30
AGENT_MAX_AUTO_CONTINUE_BATCHES=3
AGENT_MAX_TOKENS=32768
AGENT_FINAL_MAX_TOKENS=8192

# Docker sandbox — routes all terminal/background commands through an isolated
# Linux container so the agent always has a consistent POSIX environment with
# apt-get access, regardless of the host OS.
# Requires Docker to be installed and running.
AGENT_SANDBOX=
AGENT_SANDBOX_HOST_FALLBACK=false

# ── Command approval (human-in-the-loop) ──────────────────────────────────────
# Make the agent pause and ask before running commands:
#   off    — never ask (default)
#   risky  — ask only for dangerous commands (sudo, rm -rf, curl|sh, --force, …)
#   all    — ask before every terminal/background command
# Approve/deny from the dashboard banner; unanswered requests deny after timeout.
# AGENT_REQUIRE_APPROVAL=off
# AGENT_APPROVAL_TIMEOUT=120
# AGENT_SANDBOX_IMAGE=python:3.12-slim   # default; override for richer tooling
# AGENT_SANDBOX_MEMORY=1g
# AGENT_SANDBOX_CPUS=1.0
# AGENT_SANDBOX_PIDS=256
# Baseline packages auto-installed in every new sandbox container.
# AGENT_SANDBOX_BASELINE_PACKAGES=curl,wget,git,unzip,procps
#
# Serverless backend: set AGENT_SANDBOX=http to route commands at a remote
# exec shim in front of any serverless sandbox (Daytona, E2B, Modal, Vercel
# Sandbox). The shim exposes one endpoint: POST {url}/exec with
# {command,cwd,timeout,stdin?,background?,log_path?} -> {exit_code,stdout,stderr,pid?}.
# AGENT_SANDBOX=http
# AGENT_SANDBOX_EXEC_URL=http://localhost:9000
# AGENT_SANDBOX_EXEC_TOKEN=           # optional bearer token
# AGENT_SANDBOX_EXEC_WORKDIR=/workspace

# ── Alternative model providers ───────────────────────────────────────────────
# The agent uses LiteLLM internally, so any supported provider works — just
# swap the model string and set the matching API key.
# See ollama.env.example for a full provider reference.
#
# Ollama (local, private — no internet required after model download):
# AGENT_MODEL=ollama/llama3.2
# FAST_AGENT_MODEL=ollama/llama3.2
# STRONG_AGENT_MODEL=ollama/llama3.3:70b
# (remove or leave blank MOONSHOT_API_KEY / MOONSHOT_API_BASE)
#
# OpenRouter (hosted open models, many free-tier):
# AGENT_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct
# FAST_AGENT_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct
# STRONG_AGENT_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct
# OPENROUTER_API_KEY=sk-or-...
#
# Other cloud providers (set the matching *_API_KEY env var):
# AGENT_MODEL=claude-sonnet-4-5    ANTHROPIC_API_KEY=sk-ant-...
# AGENT_MODEL=gpt-4o               OPENAI_API_KEY=sk-...

# ── Optional: messaging adapters ──────────────────────────────────────────────
# Set a bot token to enable that channel.  Both run alongside the control-panel
# UI — leave unset (or omit) to disable.
#
# Telegram — create a bot via @BotFather, paste the token here:
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_IDS=          # comma-separated chat_ids; unset = open to all
#
# Discord — create a bot at discord.com/developers, copy the token here.
# Also enable "MESSAGE CONTENT INTENT" under Bot → Privileged Gateway Intents.
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USER_IDS=      # comma-separated user_ids; unset = open to all
#
# Slack — create an app at api.slack.com/apps, enable Socket Mode, add a bot
# token (xoxb-, scope chat:write) and an app-level token (xapp-, scope
# connections:write), and subscribe to message events.
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_ALLOWED_USERS=           # comma-separated user_ids; unset = open to all
#
# Voice notes — transcribe Telegram voice/audio messages via any LiteLLM STT
# model (leave blank to disable). Needs the matching provider key above.
# AGENT_TRANSCRIBE_MODEL=whisper-1            # OpenAI; or e.g. groq/whisper-large-v3

# ── Self-improving skills (evidence-gated evolution) ──────────────────────────
# Skills are versioned; improvements are only promoted if they pass a validation
# gate, and a promoted version is automatically rolled back if it measurably
# regresses against its predecessor.
# SKILL_IMPROVE_AFTER_USES=5         # synthesise an improvement after N uses
# SKILL_IMPROVE_AFTER_FAILURES=2     # …or after N failures since last improve
# SKILL_ROLLBACK_MIN_SAMPLES=4       # uses of a new version before it can be judged
# SKILL_ROLLBACK_MARGIN=0.15         # roll back if success rate drops >15% vs prev
