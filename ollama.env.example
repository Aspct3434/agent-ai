# Run agent-ai with a local Ollama model — no paid API key required.
#
# Prerequisites
# -------------
# 1. Install Ollama:  https://ollama.com
# 2. Pull a model:    ollama pull llama3.2
# 3. Copy to .env:    cp ollama.env.example an-api.env
# 4. Start:           docker compose up   (or: uvicorn gateway:app --app-dir src)
#
# Ollama listens on http://localhost:11434 by default.
# LiteLLM routes "ollama/<model>" there automatically — no extra env vars needed.

AGENT_MODEL=ollama/llama3.2
FAST_AGENT_MODEL=ollama/llama3.2
STRONG_AGENT_MODEL=ollama/llama3.2

AGENT_ACTION_MAX_REACT_ITERATIONS=24
AGENT_MAX_AUTO_CONTINUE_BATCHES=2
AGENT_MAX_TOKENS=8192
AGENT_FINAL_MAX_TOKENS=4096

AGENT_SANDBOX=
AGENT_SANDBOX_HOST_FALLBACK=false

# ── Other recommended local models ────────────────────────────────────────────
# Faster / smaller (good for FAST_AGENT_MODEL):
#   ollama/qwen2.5:7b
#   ollama/mistral
#
# Stronger / larger (good for STRONG_AGENT_MODEL, needs 16 GB+ VRAM):
#   ollama/llama3.3:70b
#   ollama/qwen2.5:72b
#   ollama/deepseek-r1:32b

# ── Ollama on a remote host ────────────────────────────────────────────────────
# If Ollama runs on a different machine, point LiteLLM at it:
# OLLAMA_API_BASE=http://192.168.1.10:11434

# ── vLLM (OpenAI-compatible server) ───────────────────────────────────────────
# vLLM exposes an OpenAI-compatible REST API; set any model name and the base URL.
# vLLM ignores the API key value.
#
# AGENT_MODEL=openai/meta-llama/Llama-3.2-8B-Instruct
# FAST_AGENT_MODEL=openai/meta-llama/Llama-3.2-8B-Instruct
# STRONG_AGENT_MODEL=openai/meta-llama/Llama-3.3-70B-Instruct
# OPENAI_API_KEY=dummy
# OPENAI_API_BASE=http://localhost:8000/v1

# ── OpenRouter (hosted open models, many free-tier) ────────────────────────────
# 400+ models with a single API key.
#
# AGENT_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct
# FAST_AGENT_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct
# STRONG_AGENT_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct
# OPENROUTER_API_KEY=sk-or-...

# ── Other cloud providers ──────────────────────────────────────────────────────
# Anthropic:    AGENT_MODEL=claude-sonnet-4-5         ANTHROPIC_API_KEY=sk-ant-...
# OpenAI:       AGENT_MODEL=gpt-4o                    OPENAI_API_KEY=sk-...
# Gemini:       AGENT_MODEL=gemini/gemini-2.0-flash   GEMINI_API_KEY=...
# Azure OpenAI: AGENT_MODEL=azure/<deployment>        AZURE_API_KEY=...  AZURE_API_BASE=...
# Kimi/Moonshot: AGENT_MODEL=moonshot/kimi-k2.6       MOONSHOT_API_KEY=...
